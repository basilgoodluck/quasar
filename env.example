# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=quasar
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Agent
AGENT_ID=1
AGENT_WALLET_ADDRESS=your_wallet_address
AGENT_WALLET_PRIVATE_KEY=your_wallet_private_key
AGENT_REGISTRY_ADDRESS=your_agent_registry_address
RISK_ROUTER_ADDRESS=your_risk_router_address
HACKATHON_VAULT_ADDRESS=your_hackathon_vault_address
VALIDATION_REGISTRY_ADDRESS=your_validation_registry_address

# Kraken
KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_API_SECRET=your_kraken_api_secret
KRAKEN_CLI_PATH=kraken
KRAKEN_PAPER_MODE=true

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# Discord / Telegram
DISCORD_WEBHOOK_URL=your_discord_webhook
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Frontend
FRONTEND_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# Models & Training
MODEL_PATH=models/regime_lstm.pt
TRAIN_INTERVAL=15m
TRAIN_WINDOW=96

# Risk & Leverage
MAX_LEVERAGE=10.0
MIN_LEVERAGE=2.0
MAX_RISK_PCT=1.5
MIN_RISK_PCT=0.25
MAX_RR=4.0
MIN_RR=1.5

# Regime thresholds
REGIME_BEAR_THRESHOLD=0.4
REGIME_BULL_THRESHOLD